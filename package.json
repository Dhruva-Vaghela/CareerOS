{
  "name": "careeros-ai",
  "version": "1.0.0",
  "description": "CareerOS AI Platform Foundation",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "prebuild": "rimraf \"packages/*/dist\" \"services/*/dist\"",
    "build": "tsc -b",
    "dev": "npm run db:up && tsx watch services/health-check/src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"{packages,services}/**/*.ts\"",
    "format": "prettier --write \"{packages,services}/**/*.ts\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm run db:migrate --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
